<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme (no action bar) -->
    <style name="Theme.WebDavPlayer" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.WebDavPlayer.Splash" parent="Theme.WebDavPlayer">
        <item name="android:windowSplashScreenBackground">@color/primary</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
    </style>
</resources>
